generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// Enums de Domínio
// ─────────────────────────────────────────────────────────

/// Classe de ativo financeiro
enum TipoClasse {
  ACOES
  FIIS
  ETFS
  RENDA_FIXA
}

/// Tipo de movimentação em carteira
enum TipoTransacao {
  COMPRA
  VENDA
}

/// Tipo de provento recebido
enum TipoProvento {
  DIVIDENDO
  JCP
  RENDIMENTO
}

// ─────────────────────────────────────────────────────────
// Modelos de Autenticação (NextAuth / Auth.js)
// ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Suporta login com credenciais
  accounts      Account[]
  sessions      Session[]

  // Relacionamentos com a carteira
  ativos        Ativo[]
  historicos    HistoricoPatrimonio[]
  metasClasses  MetaClasse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────
// Modelos da Aplicação de Carteira
// ─────────────────────────────────────────────────────────

model Ativo {
  id                String       @id @default(uuid())
  simbolo           String
  nome              String
  classe            TipoClasse
  setor             String?
  logoUrl           String?
  percentualIdeal   Float        @default(0)
  precoAtual        Float        @default(0)
  ultimoProvento    Float        @default(0)
  taxaRentabilidade Float        @default(100)
  transacoes        Transacao[]
  proventos         Provento[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, simbolo])
}

model Transacao {
  id            String        @id @default(uuid())
  ativoId       String
  ativo         Ativo         @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  data          DateTime      @default(now())
  tipo          TipoTransacao
  quantidade    Float
  precoUnitario Float
  createdAt     DateTime      @default(now())
}

model Provento {
  id         String      @id @default(uuid())
  ativoId    String
  ativo      Ativo       @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  data       DateTime    @default(now())
  tipo       TipoProvento
  valorTotal Float
  createdAt  DateTime    @default(now())
}

/// Metas de alocação por classe — isoladas por usuário
model MetaClasse {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  classe          TipoClasse
  percentualIdeal Float
  updatedAt       DateTime   @updatedAt

  @@unique([userId, classe]) // Cada usuário tem sua própria meta por classe
}

model HistoricoPatrimonio {
  id              String   @id @default(uuid())
  data            DateTime @default(now())
  patrimonioTotal Float
  totalInvestido  Float
  lucroPrejuizo   Float
  createdAt       DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
