generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// Enums de Domínio
// ─────────────────────────────────────────────────────────

/// Classe de ativo financeiro
enum TipoClasse {
  ACOES_NACIONAIS
  ACOES_INTERNACIONAIS
  FIIS
  REITS
  CRIPTO
  RENDA_FIXA
  RENDA_FIXA_INTERNACIONAL
}

/// Tipo de movimentação em carteira
enum TipoTransacao {
  COMPRA
  VENDA
}

/// Tipo de provento recebido
enum TipoProvento {
  DIVIDENDO
  JCP
  RENDIMENTO
}

// ─────────────────────────────────────────────────────────
// Modelos de Autenticação (NextAuth / Auth.js)
// ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Suporta login com credenciais
  accounts      Account[]
  sessions      Session[]

  // Relacionamentos com a carteira
  ativos        Ativo[]
  historicos    HistoricoPatrimonio[]
  metasClasses  MetaClasse[]
  questions     Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────
// Modelos da Aplicação de Carteira
// ─────────────────────────────────────────────────────────

model Ativo {
  id                String                @id @default(uuid())
  simbolo           String
  nome              String
  classe            TipoClasse
  setor             String?
  logoUrl           String?
  percentualIdeal   Decimal               @default(0) @db.Decimal(10, 4)
  precoAtual        Decimal               @default(0) @db.Decimal(12, 4)
  ultimoProvento    Decimal               @default(0) @db.Decimal(12, 4)
  taxaRentabilidade Decimal               @default(100) @db.Decimal(10, 4)
  nota              Float                 @default(10) // Nota de 0 a 10 (Diagrama AUVP)
  transacoes        Transacao[]
  proventos         Provento[]
  answers           AssetQuestionAnswer[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, simbolo])
  @@index([userId])
}

model Question {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criterio  String   // ex: ROE, CAGR, Governança
  pergunta  String   // ex: ROE historicamente maior que 5%?
  isDefault Boolean  @default(false)
  peso      Float    @default(1.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers AssetQuestionAnswer[]

  @@index([userId])
}

model AssetQuestionAnswer {
  id         String   @id @default(uuid())
  ativoId    String
  ativo      Ativo    @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  @@unique([ativoId, questionId])
  @@index([ativoId])
  @@index([questionId])
}

model Transacao {
  id            String        @id @default(uuid())
  ativoId       String
  ativo         Ativo         @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  data          DateTime      @default(now())
  tipo          TipoTransacao
  quantidade    Decimal       @db.Decimal(15, 6)
  precoUnitario Decimal       @db.Decimal(15, 6)
  createdAt     DateTime      @default(now())

  @@index([ativoId])
}

model Provento {
  id         String      @id @default(uuid())
  ativoId    String
  ativo      Ativo       @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  data       DateTime    @default(now())
  tipo       TipoProvento
  valorTotal Decimal     @db.Decimal(15, 6)
  createdAt  DateTime    @default(now())

  @@index([ativoId])
}

/// Metas de alocação por classe — isoladas por usuário
model MetaClasse {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  classe          TipoClasse
  percentualIdeal Decimal    @db.Decimal(10, 4)
  updatedAt       DateTime   @updatedAt

  @@unique([userId, classe])
  @@index([userId])
}

model HistoricoPatrimonio {
  id              String   @id @default(uuid())
  data            DateTime @default(now())
  patrimonioTotal Decimal  @db.Decimal(15, 2)
  totalInvestido  Decimal  @db.Decimal(15, 2)
  lucroPrejuizo   Decimal  @db.Decimal(15, 2)
  createdAt       DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
